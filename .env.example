# ── Provider Selection ─────────────────────────────────────────────────
# Set PROVIDER explicitly, or leave blank for auto-detection:
#   - "anthropic"   → uses ANTHROPIC_API_KEY
#   - "azure"       → uses AZURE_AI_ENDPOINT + AZURE_AI_API_KEY
#   - "claude-code" → uses Claude Code CLI (requires: npm install -g @anthropic-ai/claude-code)
# PROVIDER=

# ── Option 1: Anthropic API (recommended) ─────────────────────────────
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5-20250514

# ── Option 2: Azure AI Foundry ────────────────────────────────────────
# AZURE_AI_ENDPOINT=https://your-resource.services.ai.azure.com/anthropic/
# AZURE_AI_API_KEY=your-api-key
# AZURE_AI_MODEL=claude-sonnet
# AZURE_AI_API_VERSION=2024-12-01-preview

# ── Option 3: Claude Code CLI ─────────────────────────────────────────
# No API key needed — uses your Claude Code subscription.
# Requires: npm install -g @anthropic-ai/claude-code
#           pip install langchain-claude-code
# PROVIDER=claude-code
# CLAUDE_CODE_MODEL=sonnet   # opus, sonnet, or haiku
